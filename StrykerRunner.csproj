<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <!-- Tool configuration -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>stryker-runner</ToolCommandName>
    <PackageId>StrykerRunner</PackageId>
    <Version>1.0.0</Version>
    <Authors>Joeri van Arkel</Authors>
    <Description>A .NET tool to run Stryker mutation testing across multiple projects and generate unified reports</Description>
    <PackageProjectUrl>https://github.com/joerivanarkel/StrykerRunner</PackageProjectUrl>
    <RepositoryUrl>https://github.com/joerivanarkel/StrykerRunner</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
